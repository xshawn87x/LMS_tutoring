# ============================================================
# 운영 배포 환경변수 예시 — 이 파일을 .env 로 복사한 뒤 값을 채우세요.
# .env 는 .gitignore 되어 커밋되지 않습니다.  사용: docker compose -f docker-compose.prod.yml up -d
# ============================================================

# --- 프로파일 (운영 하드닝 활성화: dev 토큰 비활성·Swagger 비공개·기동 시크릿 검사) ---
SPRING_PROFILES_ACTIVE=prod

# --- 필수 시크릿 (약하면 ProductionReadinessGuard가 기동을 차단) ---
# 32자 이상 무작위:  openssl rand -base64 48
LMS_JWT_SECRET=CHANGE_ME_random_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 플랫폼(SaaS 제공자) 슈퍼관리자 로그인
LMS_PLATFORM_ADMIN_EMAIL=admin@your-domain.com
LMS_PLATFORM_ADMIN_PASSWORD=CHANGE_ME_strong_password

# --- 데이터베이스 (owner=마이그레이션 실행 롤) ---
POSTGRES_OWNER_PASSWORD=CHANGE_ME_strong_db_owner_pw
# 앱 접속 롤(lms_app)의 비밀번호는 마이그레이션 기본값(lms_app_pw)입니다.
# 운영에서 교체하려면 DEPLOY.md의 "DB 롤 비밀번호 교체" 절차를 따르고 아래 값을 맞추세요.
LMS_APP_DB_PASSWORD=lms_app_pw

# --- 도메인 (Caddy 자동 HTTPS) ---
APP_DOMAIN=your-domain.com
API_DOMAIN=api.your-domain.com
# 브라우저가 호출할 백엔드 공개 주소 (프론트 빌드에 박힘)
NEXT_PUBLIC_API_BASE=https://api.your-domain.com

# --- 이메일(SMTP) — 학부모 리포트/알림 실발송 (선택; 미설정 시 SIMULATED) ---
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
APP_MAIL_FROM=no-reply@your-domain.com

# --- 결제 PG (선택; 붙일 때 DEPLOY.md 참고) ---
APP_PAYMENT_PROVIDER=mock
# APP_PAYMENT_TOSS_SECRET_KEY=

# --- SMS/알림톡 (선택; 현재 스텁) ---
# APP_SMS_PROVIDER=nhncloud

# --- AI 콘텐츠 분석 (선택) ---
# ANTHROPIC_API_KEY=
